<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- A single, pinned source. clear drops any inherited/global feeds so the
         restore graph cannot pull from an unexpected origin. -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <!-- Every package id is mapped to the single source. With one source the
       mapping is belt-and-braces, but it makes the restore origin explicit and
       blocks a second feed from ever silently satisfying a package id (a
       dependency-confusion guard). -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>

  <!-- Disable machine-wide fallback folders so a package can only come from the
       pinned source above, never from a pre-seeded offline folder. -->
  <fallbackPackageFolders>
    <clear />
  </fallbackPackageFolders>
</configuration>
