root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.{json,yml,yaml}]
indent_size = 2

[*.{csproj,sln,slnx}]
indent_size = 2

[*.cs]
indent_size = 4

# C# naming conventions
dotnet_naming_rule.public_members_must_be_pascal_case.severity = warning
dotnet_naming_rule.public_members_must_be_pascal_case.symbols = public_symbols
dotnet_naming_rule.public_members_must_be_pascal_case.style = pascal_case

dotnet_naming_symbols.public_symbols.applicable_kinds = class, struct, interface, enum, property, method, event, namespace
dotnet_naming_symbols.public_symbols.applicable_accessibilities = public, internal

dotnet_naming_style.pascal_case.capitalization = pascal_case

# Private fields prefixed with underscore
dotnet_naming_rule.private_fields_underscore.severity = warning
dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_prefix

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.underscore_prefix.capitalization = camel_case
dotnet_naming_style.underscore_prefix.required_prefix = _

# Private const fields use PascalCase (constants are not subject to the
# underscore-prefix rule). Listed before private_fields_underscore so it wins
# for symbols matching both.
dotnet_naming_rule.private_const_fields_pascal.severity = warning
dotnet_naming_rule.private_const_fields_pascal.symbols = private_const_fields
dotnet_naming_rule.private_const_fields_pascal.style = pascal_case

dotnet_naming_symbols.private_const_fields.applicable_kinds = field
dotnet_naming_symbols.private_const_fields.applicable_accessibilities = private
dotnet_naming_symbols.private_const_fields.required_modifiers = const

# Same-line braces
csharp_new_line_before_open_brace = none
csharp_new_line_before_else = false
csharp_new_line_before_catch = false
csharp_new_line_before_finally = false

# ---------------------------------------------------------------------------
# Local SonarAnalyzer gate (scoped) — see Directory.Build.props.
#
# SonarAnalyzer.CSharp activates a large default ruleset; left unscoped, with
# TreatWarningsAsErrors it would fail the build on a backlog of pre-existing
# issues across the whole tree. So every analyzer diagnostic defaults to none
# here, and only the rules that have repeatedly slipped into CI as new-code
# issues are opted back in (as warnings → errors). Widen this list deliberately,
# not by accident. Explicit per-rule severities (and the naming rules above)
# override this default, so style/naming enforcement is unaffected.
# ---------------------------------------------------------------------------
[*.cs]
dotnet_analyzer_diagnostic.severity = none

# Production code only. CI excludes test files from issue analysis
# (sonar.test.exclusions), so the gate matches that scope: these rules are not
# opted in for tests/**.
# Deterministic, false-positive-free rules only. S125 (commented-out code) is
# deliberately NOT gated: it false-positives on the explanatory comments a
# compiler necessarily writes (those mentioning `if (x != nil)`, `T { }`,
# `(Unknown)` etc.), so a hard gate would force rewording legitimate prose. Watch
# S125 by eye on new comments instead; keep them from parsing as code.
[src/**/*.cs]
dotnet_diagnostic.S3776.severity = warning   # cognitive complexity > 15
dotnet_diagnostic.S2219.severity = warning   # 'is T' that is really a null check
dotnet_diagnostic.S2325.severity = warning   # member can be static
dotnet_diagnostic.CA1822.severity = warning  # member can be static (.NET analyzer twin)

# Hot-path carve-outs — mirror sonar.issue.ignore.multicriteria (e2, e6) in
# .github/workflows/sonarcloud.yml. The VM dispatch loop and the type-cycle
# walker exceed S3776 by design (D-302, branch-free dispatch); see
# complexity-vs-performance-hot-paths. Keep these two lists in lockstep.
[src/Grob.Vm/VirtualMachine.cs]
dotnet_diagnostic.S3776.severity = none

[src/Grob.Compiler/TypeChecker.TypeCycles.cs]
dotnet_diagnostic.S3776.severity = none
