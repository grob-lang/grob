// Sprint 4 control-flow benchmark fixture.
// Exercises while + select dispatch over 100 iterations.
// print() output is discarded by TextWriter.Null in the harness.
result := 0
i := 0
while (i < 100) {
    r := i % 4
    select (r) {
        case 0 { result = result + 1 }
        case 1 { result = result + 3 }
        case 2 { result = result + 5 }
        case 3 { result = result + 7 }
    }
    i++
}
print(result)
