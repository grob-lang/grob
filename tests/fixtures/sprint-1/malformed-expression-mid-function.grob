// function with the rest of the AST intact, and continue parsing the
// surrounding top-level declarations cleanly. Exactly one diagnostic
// should be emitted for this file.
fn first(): Int {
    return 1
}

fn broken(a: Int): Int {
    return a +
}

fn last(): Int {
    return 42
}
