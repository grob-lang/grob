// E5902 — a genuine value-binding initialisation cycle (D-321, §19.1). While
// 'a' is initialising, its initialiser calls computeA(), whose body reads 'b';
// 'b' has not yet been initialised, so the read halts at runtime. Functions are
// hoisted, so this is a value cycle — not a forward call (which is now legal).
readonly a := computeA()
readonly b := computeB()

fn computeA(): int {
    return b + 1
}

fn computeB(): int {
    return a + 1
}

print(a)
